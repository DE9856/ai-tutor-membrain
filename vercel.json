{
  "version": 2,
  "builds": [
    {
      "src": "frontend/app.py",
      "use": "@vercel/python",
      "config": {
        "installCommand": "pip install --upgrade pip && pip install -r frontend/requirements.txt",
        "pythonVersion": "3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/app.py"
    }
  ],
  "env": {
    "BACKEND_API_URL": "https://ai-tutor-backend-mir3.onrender.com",
    "USE_MOCK_MODE": "false",
    "PYTHON_VERSION": "3.11"
  }
}